# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_CHAT_ID=       # ID канала, откуда забирать посты
TELEGRAM_CHAT_ID=               # ID чата для уведомлений (опционально)

# VK
VK_TOKEN=                       # Ключ доступа сообщества (group token)
VK_OWNER_ID=                    # ID группы со знаком минус, например -123456789
VK_ALBUM_ID=                    # ID альбома для фото
VK_ENABLED=true

# LinkedIn
LINKEDIN_TOKEN=                 # Access token LinkedIn
LINKEDIN_AUTHOR_URN=            # URN автора, например urn:li:person:...
LINKEDIN_ENABLED=true

# Max
MAX_BOT_TOKEN=                  # Токен бота Max
MAX_CHANNEL_ID=                 # ID канала в Max
MAX_ENABLED=true

# AI (для адаптации текста VK и LinkedIn)
OPENAI_API_KEY=                 # OpenAI API key (опционально, fallback для Gemini)
GEMINI_API_KEY=                 # Google Gemini API key (опционально)
